<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent" android:padding="12dp">
    <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content">
        <TextView android:text="MY IDENTITY" android:textStyle="bold" android:layout_width="match_parent" android:layout_height="wrap_content" />
        <TextView android:id="@+id/setHash" android:text="Loading..." android:background="#F0F0F0" android:padding="10dp" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="10dp" />
        <EditText android:id="@+id/setNick" android:hint="Your Nickname" android:layout_width="match_parent" android:layout_height="wrap_content" />
        
        <TextView android:text="RNODE CONNECTION" android:textStyle="bold" android:layout_marginTop="15dp" android:layout_width="match_parent" android:layout_height="wrap_content" />
        <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content">
            <Spinner android:id="@+id/setBtSpinner" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" />
            <Button android:id="@+id/btnRefreshBt" android:text="Refresh" android:layout_width="wrap_content" android:layout_height="wrap_content" />
        </LinearLayout>
        <Button android:id="@+id/btnSetConnect" android:text="Connect RNode" android:layout_width="match_parent" android:layout_height="wrap_content" />

        <TextView android:text="RADIO PARAMETERS" android:textStyle="bold" android:layout_marginTop="15dp" android:layout_width="match_parent" android:layout_height="wrap_content" />
        <TextView android:text="Region" android:textSize="10sp" android:layout_width="match_parent" android:layout_height="wrap_content" />
        <Spinner android:id="@+id/spinRegion" android:layout_width="match_parent" android:layout_height="wrap_content" />
        
        <TextView android:text="Bandwidth" android:textSize="10sp" android:layout_width="match_parent" android:layout_height="wrap_content" />
        <Spinner android:id="@+id/spinBw" android:layout_width="match_parent" android:layout_height="wrap_content" />
        
        <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content">
            <LinearLayout android:orientation="vertical" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
                <TextView android:text="SF" android:textSize="10sp" android:layout_width="match_parent" android:layout_height="wrap_content" />
                <Spinner android:id="@+id/spinSf" android:layout_width="match_parent" android:layout_height="wrap_content" />
            </LinearLayout>
            <LinearLayout android:orientation="vertical" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
                <TextView android:text="CR" android:textSize="10sp" android:layout_width="match_parent" android:layout_height="wrap_content" />
                <Spinner android:id="@+id/spinCr" android:layout_width="match_parent" android:layout_height="wrap_content" />
            </LinearLayout>
        </LinearLayout>
        
        <Button android:id="@+id/btnSaveSettings" android:text="Save &amp; Apply All" android:layout_marginTop="15dp" android:layout_width="match_parent" android:layout_height="wrap_content" />
    </LinearLayout>
</ScrollView>