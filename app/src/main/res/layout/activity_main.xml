<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="10dp">

    <TextView android:id="@+id/addressDisplay" android:layout_width="match_parent" android:layout_height="wrap_content" 
        android:text="RNS Address: Loading..." android:textSize="12sp" android:textStyle="bold" />

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="5dp">
        <Spinner android:id="@+id/btSpinner" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" />
        <Button android:id="@+id/btnRefreshBt" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Refresh" android:textSize="10sp" />
        <Button android:id="@+id/btnConnectBt" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Connect" android:textSize="10sp" />
    </LinearLayout>

    <Button android:id="@+id/btnBroadcast" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Broadcast Identity (Announce)" android:layout_marginTop="5dp" />

    <TextView android:id="@+id/targetNodeInfo" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="No target node selected." android:layout_marginTop="10dp" android:textSize="12sp" />
    
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/chatRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#F0F0F0"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Discovered Nodes (Tap to Chat):" android:layout_marginTop="10dp" android:textSize="12sp" />
    <ListView android:id="@+id/discoveredNodesList" android:layout_width="match_parent" android:layout_height="100dp" android:background="#E0E0E0" />

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
        <EditText android:id="@+id/messageInput" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:hint="Type message..." />
        <Button android:id="@+id/btnAttach" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="IMG" />
        <Button android:id="@+id/btnSend" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SEND" />
    </LinearLayout>
</LinearLayout>
